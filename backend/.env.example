# Copy this file to .env and fill in real values for local development.
# On Render, set these as Environment Variables in the dashboard.

DB_URL=jdbc:postgresql://localhost:5432/yourdb
DB_USERNAME=youruser
DB_PASSWORD=yourpassword

MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

SETTINGS_ENCRYPTION_KEY=
OPENROUTER_API_KEY=

FRONTEND_BASE_URL=http://localhost:8081
