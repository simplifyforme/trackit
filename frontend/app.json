{
  "expo": {
    "name": "TemplateApp",
    "slug": "template-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "templateapp",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.templateapp"
    },
    "android": {
      "package": "com.example.templateapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F6EF7"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fdfe5e3f-948e-4a51-a030-5bb2a4ac25c5"
      }
    }
  }
}
